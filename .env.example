# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgres://postgres:postgres@localhost:5432/callipsos_dev

# ── Lit Protocol Signing (Chipotle REST API) ─────────────────
# All 3 must be set to enable signing. If any is missing, signing
# is disabled and the validate endpoint still works without signatures.
#
# Get these from the Chipotle Dashboard: https://dashboard.dev.litprotocol.com
# 1. Create account → get account API key
# 2. Create usage API key → LIT_API_KEY
# 3. Create PKP wallet → LIT_PKP_PUBLIC_KEY
# 4. Create group, add PKP to group
LIT_API_URL=https://api.dev.litprotocol.com
LIT_API_KEY=
LIT_PKP_PUBLIC_KEY=